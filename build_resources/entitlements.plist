<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- Allow reading process memory and system info -->
    <key>com.apple.security.cs.allow-unsigned-executable-memory</key>
    <true/>

    <!-- Allow JIT compilation (needed by Python) -->
    <key>com.apple.security.cs.allow-jit</key>
    <true/>

    <!-- Disable library validation (for bundled .so/.dylib) -->
    <key>com.apple.security.cs.disable-library-validation</key>
    <true/>

    <!-- Allow reading /proc equivalents and system diagnostics -->
    <key>com.apple.security.device.usb</key>
    <true/>

    <!-- Full Disk Access entitlement (user must grant in System Settings) -->
    <key>com.apple.security.files.all</key>
    <true/>
</dict>
</plist>
